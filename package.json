{
  "name": "beatrice-voice-changer",
  "version": "1.0.0",
  "description": "Real-time AI voice changer powered by the Beatrice DSP engine and JVS corpus speakers",
  "main": "main.js",
  "author": "Jatin Pandey <satiricalguru>",
  "homepage": "https://github.com/satiricalguru/beatrice-voicechanger",
  "repository": {
    "type": "git",
    "url": "https://github.com/satiricalguru/beatrice-voicechanger.git"
  },
  "scripts": {
    "start": "electron .",
    "dev": "electron . --enable-logging",
    "dist": "electron-builder --mac --publish never",
    "dist:win": "electron-builder --win --publish never"
  },
  "keywords": [
    "voice-changer",
    "beatrice",
    "real-time",
    "DSP",
    "electron",
    "ai"
  ],
  "license": "MIT",
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.satiricalguru.beatrice-voice-changer",
    "productName": "Beatrice Voice Changer",
    "copyright": "Copyright © 2026 Jatin Pandey",
    "directories": {
      "output": "dist"
    },
    "asarUnpack": [
      "beatrice_audio.py",
      "beatrice_loader.py",
      "requirements.txt",
      "beatrice_paraphernalia_jvs/**/*",
      "beatrice_2.0.0-rc.2.vst3/**/*"
    ],
    "files": [
      "main.js",
      "renderer.js",
      "index.html",
      "index.css",
      "beatrice_audio.py",
      "beatrice_loader.py",
      "requirements.txt",
      "icon.png",
      "icon.icns",
      "beatrice_paraphernalia_jvs/**/*",
      "beatrice_2.0.0-rc.2.vst3/**/*"
    ],
    "extraResources": [
      {
        "from": "beatrice_paraphernalia_jvs",
        "to": "beatrice_paraphernalia_jvs",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "beatrice_2.0.0-rc.2.vst3",
        "to": "beatrice_2.0.0-rc.2.vst3",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.music",
      "icon": "icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "darkModeSupport": true,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "dmg": {
      "title": "Beatrice Voice Changer",
      "icon": "icon.icns",
      "contents": [
        {
          "x": 150,
          "y": 220,
          "type": "file"
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 560,
        "height": 400
      }
    }
  }
}
